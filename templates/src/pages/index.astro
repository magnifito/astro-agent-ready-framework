---
import BaseLayout from "~/layouts/BaseLayout.astro";
import {
  faqPage,
  graph,
  offerCatalog,
  organization,
  service as serviceNode,
  webPage,
  webSite,
} from "~/lib/schema";
import { services } from "~/data/services";
import { insights } from "~/data/insights";
import { getSiteUrl, siteInfo } from "~/data/site";

// Homepage archetype (framework.md §3): Organization + WebSite (SearchAction) +
// WebPage (speakable) + OfferCatalog + per-Service nodes + FAQPage. Content
// structure follows §6/§9/§10 — single h1 + intro that answers "what is this
// site", services, insights teaser, FAQ (rendered AND fed into FAQPage from the
// SAME array), trust-signals aside, and a no-JS contact form.
const siteUrl = getSiteUrl(Astro.site);
const canonicalHref = `${siteUrl}/`;
const title = `${siteInfo.name} — ${siteInfo.tagline}`;
const description = siteInfo.description;

// FAQ array — rendered into the DOM (question-formatted <h3>s) AND passed to
// faqPage() below, so the visible copy and the JSON-LD never drift (audits 9.1,
// 3.7). Fill the $FAQ_* tokens with real question/answer copy before build.
const faqs = [
  { question: "$FAQ_1_QUESTION", answer: "$FAQ_1_ANSWER" },
  { question: "$FAQ_2_QUESTION", answer: "$FAQ_2_ANSWER" },
  { question: "$FAQ_3_QUESTION", answer: "$FAQ_3_ANSWER" },
];

// Contact form posts to the form processor and returns to /thank-you/
// (ConfirmAction archetype). redirect is absolute so the processor can honour it.
const formEndpoint = "$FORM_ENDPOINT";
const thankYouUrl = new URL("/thank-you/", siteUrl).toString();

const structuredData = graph(
  organization(siteUrl),
  webSite(siteUrl),
  webPage({
    siteUrl,
    canonicalHref,
    title,
    description,
    // Selectors MUST resolve to real elements on this page (audit 3.9).
    speakable: ["h1", ".site-intro"],
  }),
  offerCatalog(services, siteUrl),
  // Service nodes the OfferCatalog references by @id — keep them in the graph.
  ...services.map((s) =>
    serviceNode({
      siteUrl,
      canonicalHref: new URL(s.href, siteUrl).toString(),
      name: s.title,
      description: s.summary,
    }),
  ),
  faqPage(faqs, siteUrl),
);

const teaserInsights = insights.slice(0, 2);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  type="website"
  includeSitemaps={true}
  structuredData={structuredData}
>
  <div class="mx-auto max-w-5xl">
    {/* —— Hero: single <h1>, tagline, and an intro that answers the "what is
        this site" question in the first paragraph (audits 6.1, 9.3). —— */}
    <section aria-labelledby="hero-heading">
      <h1 id="hero-heading" class="text-4xl leading-tight font-black sm:text-6xl">
        {siteInfo.name}
      </h1>
      <p class="text-mint mt-4 text-lg font-semibold">{siteInfo.tagline}</p>
      <p class="site-intro text-muted mt-6 max-w-2xl text-lg leading-8">
        $SITE_LONG_DESCRIPTION
      </p>
      <p class="mt-8">
        <a
          class="bg-lime text-ink inline-block rounded-md px-5 py-3 font-semibold"
          href="#contact"
          data-action="contact"
          data-action-type="lead"
          data-action-label="Hero start a project">Start a project</a
        >
      </p>
    </section>

    {/* —— Trust signals (audit 10.7). <aside> keeps this supplementary to the
        main summary (audit 6.6). Replace with real logos / metrics / press —
        do not fabricate. —— */}
    <aside class="mt-16" aria-labelledby="trust-heading">
      <h2 id="trust-heading" class="text-2xl font-black">
        Why teams choose {siteInfo.name}
      </h2>
      <p class="text-muted mt-3 leading-8">
        Add real trust signals here — client logos, testimonials, case metrics,
        certifications, or press mentions. Leave this out entirely rather than
        inventing proof {siteInfo.name} does not have.
      </p>
    </aside>

    {/* —— Services (audit 3.8, 5.17). Links carry the data-action triplet. —— */}
    <section class="mt-16" aria-labelledby="services-heading">
      <h2 id="services-heading" class="text-2xl font-black">
        What {siteInfo.name} does
      </h2>
      <ul class="mt-8 grid gap-6 sm:grid-cols-2">
        {
          services.map((s) => (
            <li>
              {/* audit 6.4 — each self-contained card is an <article> */}
              <article class="border-ink/10 h-full rounded-lg border p-6">
                <h3 class="text-xl font-black">
                  <a
                    class="text-ink"
                    href={s.href}
                    data-action="view-service"
                    data-action-type="navigation"
                    data-action-label={`View ${s.title}`}
                  >
                    {s.title}
                  </a>
                </h3>
                <p class="text-muted mt-3 leading-7">{s.summary}</p>
              </article>
            </li>
          ))
        }
      </ul>
      <p class="mt-6">
        <a class="text-ink font-semibold" href="/services/">All services</a>
      </p>
    </section>

    {/* —— Insights teaser (audit 10.11 cross-linking). —— */}
    <section class="mt-16" aria-labelledby="insights-heading">
      <h2 id="insights-heading" class="text-2xl font-black">Latest insights</h2>
      <ul class="mt-8 divide-y">
        {
          teaserInsights.map((post) => (
            <li class="py-5">
              <article>
                <h3 class="text-xl font-black">
                  <a
                    class="text-ink"
                    href={post.href}
                    data-action="read-insight"
                    data-action-type="navigation"
                    data-action-label={`Read ${post.title}`}
                  >
                    {post.title}
                  </a>
                </h3>
                <p class="text-muted mt-2 text-sm">
                  {post.author.name} —{" "}
                  <time datetime={post.publishedAt}>{post.publishedAt}</time>
                </p>
                <p class="mt-3 leading-7">{post.description}</p>
              </article>
            </li>
          ))
        }
      </ul>
      <p class="mt-6">
        <a class="text-ink font-semibold" href="/insights/">All insights</a>
      </p>
    </section>

    {/* —— FAQ (audits 9.1, 9.2, 3.7). Question-formatted <h3>s; same `faqs`
        array feeds faqPage() so DOM and JSON-LD stay in lockstep. —— */}
    <section class="faq-section mt-16" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl font-black">
        Frequently asked questions
      </h2>
      <div class="mt-8 space-y-8">
        {
          faqs.map((f) => (
            <div>
              <h3 class="text-lg font-black">{f.question}</h3>
              <p class="text-muted mt-2 leading-8">{f.answer}</p>
            </div>
          ))
        }
      </div>
    </section>

    {/* —— Contact (audits 5.15, 5.17, 5.18, 5.19, 6.12, 7.5, 7.15). Pure HTML
        form — works with JavaScript disabled. Honeypot + no CAPTCHA. —— */}
    <section id="contact" class="mt-16" aria-labelledby="contact-heading">
      <h2 id="contact-heading" class="text-2xl font-black">
        Tell {siteInfo.name} about your project
      </h2>
      <p class="text-muted mt-3 max-w-2xl leading-8">
        Send a short message about your business context and the outcome you are
        after. We reply to every genuine inquiry.
      </p>

      <form class="mt-8 max-w-xl space-y-5" action={formEndpoint} method="post">
        <input type="hidden" name="access_key" value="$FORM_ACCESS_KEY" />
        <input type="hidden" name="from_name" value={siteInfo.name} />
        <input
          type="hidden"
          name="subject"
          value={`New inquiry from ${siteInfo.name}`}
        />
        <input type="hidden" name="redirect" value={thankYouUrl} />
        {/* Honeypot — hidden from humans, tempting to bots (audit 5.18). */}
        <input
          type="checkbox"
          name="botcheck"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div>
          <label class="block font-semibold" for="contact-name">Name</label>
          <input
            class="border-ink/20 mt-2 w-full rounded-md border px-4 py-3"
            id="contact-name"
            name="name"
            type="text"
            autocomplete="name"
            required
          />
        </div>

        <div>
          <label class="block font-semibold" for="contact-email">Email</label>
          <input
            class="border-ink/20 mt-2 w-full rounded-md border px-4 py-3"
            id="contact-email"
            name="email"
            type="email"
            autocomplete="email"
            required
          />
        </div>

        <div>
          <label class="block font-semibold" for="contact-message">Message</label>
          <textarea
            class="border-ink/20 mt-2 w-full rounded-md border px-4 py-3"
            id="contact-message"
            name="message"
            rows="5"
            autocomplete="off"
            required></textarea>
        </div>

        <button
          class="bg-lime text-ink inline-block rounded-md px-5 py-3 font-semibold"
          type="submit"
          data-action="contact"
          data-action-type="lead"
          data-action-label="Homepage contact form">Send message</button
        >
      </form>

      {/* audit 6.12 — contact details wrapped in <address>. */}
      <address class="mt-8 not-italic">
        Prefer email? Reach {siteInfo.name} at{" "}
        <a class="text-ink font-semibold" href={`mailto:${siteInfo.email}`}>
          {siteInfo.email}
        </a>
      </address>
    </section>
  </div>
</BaseLayout>
