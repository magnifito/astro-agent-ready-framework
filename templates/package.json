{
  "name": "$SITE_PACKAGE_NAME",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build",
    "validate:build": "node scripts/validate-built-site.js",
    "validate:headless": "node scripts/validate-headless.js",
    "verify": "npm run build && npm run validate:build",
    "verify:deployed": "node scripts/validate-headless.js $SITE_URL",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"src/**/*.{astro,css,js,ts}\" \"scripts/**/*.js\" \"public/**/*.json\" \"*.{json,md}\"",
    "clean": "rimraf dist .astro node_modules",
    "deploy": "npm run build && node scripts/deploy.js"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@puralex/astro-markdown-for-agents": "^0.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.7",
    "astro-compressor": "^1.1.0",
    "astro-og-canvas": "^0.7.0",
    "astro-pagefind": "^1.8.0",
    "canvaskit-wasm": "^0.40.0",
    "pagefind": "^1.4.0",
    "playwright": "^1.48.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
