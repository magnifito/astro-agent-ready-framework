# Netlify / Cloudflare Pages header file.
# Use instead of public/.htaccess when deploying to these platforms.
# Syntax: path block, then indented `Header-Name: value` lines.

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-site
  # Enable HSTS only once HTTPS-only:
  # Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # Tune CSP per site:
  # Content-Security-Policy: default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; form-action 'self' https://api.web3forms.com; frame-ancestors 'self'

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/llms.txt
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

