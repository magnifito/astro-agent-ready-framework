---
import {
  absoluteUrl,
  defaultAiInstructions,
  getSiteUrl,
  markdownPathFor,
  resourcePaths,
  siteInfo,
} from "~/data/site";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  canonicalHref?: string;
  markdownPath?: string | null;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  robots?: string;
  structuredData?: unknown;
  aiInstructions?: string;
  includeSitemaps?: boolean;
  preconnectImages?: boolean;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  author?: string;        // meta author — audit 4.2, GEO 10.1
  prevHref?: string;      // rel="prev" — audit 10.12
  nextHref?: string;      // rel="next" — audit 10.12
}

const {
  title,
  description,
  canonicalPath,
  canonicalHref: canonicalHrefProp,
  markdownPath,
  image,
  imageAlt,
  type = "website",
  robots,
  structuredData,
  aiInstructions = defaultAiInstructions,
  includeSitemaps = false,
  preconnectImages = false,
  articlePublishedTime,
  articleModifiedTime,
  author,
  prevHref,
  nextHref,
} = Astro.props;

const siteUrl = getSiteUrl(Astro.site);
const path = canonicalPath ?? Astro.url.pathname;
const canonicalHref = canonicalHrefProp ?? absoluteUrl(path, siteUrl);
const markdownHref =
  markdownPath === null
    ? undefined
    : absoluteUrl(markdownPath ?? markdownPathFor(path), siteUrl);

const llmsUrl = absoluteUrl(resourcePaths.llms, siteUrl);
const llmsFullUrl = absoluteUrl(resourcePaths.llmsFull, siteUrl);
const rssUrl = absoluteUrl(resourcePaths.rss, siteUrl);
const aiCatalogUrl = absoluteUrl(resourcePaths.aiCatalog, siteUrl);
const brandUrl = absoluteUrl(resourcePaths.brand, siteUrl);
const humansUrl = absoluteUrl(resourcePaths.humans, siteUrl);
const openApiUrl = absoluteUrl(resourcePaths.openApi, siteUrl);
const mcpUrl = absoluteUrl(resourcePaths.mcp, siteUrl);
const sitemapUrl = absoluteUrl(resourcePaths.sitemap, siteUrl);
const sitemapIndexUrl = absoluteUrl(resourcePaths.sitemapIndex, siteUrl);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="canonical" href={canonicalHref} />
{
  preconnectImages && (
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
  )
}
<link rel="alternate" type="text/plain" title={`${siteInfo.name} LLM profile`} href={llmsUrl} />
<link rel="alternate" type="text/plain" title={`${siteInfo.name} full LLM context`} href={llmsFullUrl} />
{
  markdownHref && (
    <link rel="alternate" type="text/markdown" title="Markdown version" href={markdownHref} />
  )
}
<link rel="alternate" type="application/rss+xml" title={`${siteInfo.name} RSS`} href={rssUrl} />
<link rel="alternate" type="application/json" title={`${siteInfo.name} AI catalog`} href={aiCatalogUrl} />
<link rel="alternate" type="application/json" title={`${siteInfo.name} brand profile`} href={brandUrl} />
<link rel="author" type="text/plain" href={humansUrl} />
<link rel="alternate" type="application/json" title={`${siteInfo.name} OpenAPI`} href={openApiUrl} />
<link rel="alternate" type="application/json" title={`${siteInfo.name} MCP discovery`} href={mcpUrl} />
<link rel="service-desc" type="application/openapi+json" title={`${siteInfo.name} contact action`} href={openApiUrl} />
{ includeSitemaps && <link rel="sitemap" type="application/xml" href={sitemapUrl} /> }
{ includeSitemaps && <link rel="sitemap" type="application/xml" href={sitemapIndexUrl} /> }
<meta name="generator" content={Astro.generator} />
{robots && <meta name="robots" content={robots} />}
{author && <meta name="author" content={author} />}
{prevHref && <link rel="prev" href={prevHref} />}
{nextHref && <link rel="next" href={nextHref} />}
<title>{title}</title>
<meta name="description" content={description} />
<meta name="ai-content-declaration" content={llmsUrl} />
<meta name="ai-instructions" content={aiInstructions} />
<meta property="og:title" content={title} />
<meta property="og:type" content={type} />
<meta property="og:description" content={description} />
{image && <meta property="og:image" content={image} />}
{image && imageAlt && <meta property="og:image:alt" content={imageAlt} />}
<meta property="og:url" content={canonicalHref} />
<meta property="og:site_name" content={siteInfo.name} />
{ articlePublishedTime && (
  <meta property="article:published_time" content={articlePublishedTime} />
) }
{ articleModifiedTime && (
  <meta property="article:modified_time" content={articleModifiedTime} />
) }
<meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{image && <meta name="twitter:image" content={image} />}
<meta name="theme-color" content={siteInfo.themeColor} />
{
  structuredData && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  )
}
