---
import { siteInfo } from "~/data/site";
---

<footer class="bg-paper px-5 py-8 sm:px-8 lg:px-10">
  <div
    class="text-muted mx-auto flex max-w-7xl flex-col gap-5 text-sm lg:flex-row lg:items-center lg:justify-between"
  >
    <div>
      <p class="text-ink font-semibold">{siteInfo.name}</p>
      <p>{siteInfo.tagline}</p>
    </div>
    <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Footer navigation">
      <a class="text-ink font-semibold" href="/services/">Services</a>
      <a class="text-ink font-semibold" href="/insights/">Insights</a>
      <a class="text-ink font-semibold" href="/privacy/">Privacy</a>
      <a class="text-ink font-semibold" href="/terms/">Terms</a>
      <a class="text-ink font-semibold" href="/llms.txt">LLMs.txt</a>
      <a class="text-ink font-semibold" href="/sitemap.xml">Sitemap</a>
      <a class="text-ink font-semibold" href={`mailto:${siteInfo.email}`}>
        {siteInfo.email}
      </a>
    </nav>
  </div>
</footer>
