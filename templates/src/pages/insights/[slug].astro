---
import BaseLayout from "~/layouts/BaseLayout.astro";
import {
  article,
  breadcrumbs,
  graph,
  organization,
  person,
  webPage,
} from "~/lib/schema";
import { getSiteUrl, siteInfo } from "~/data/site";
import { insights, type Insight } from "~/data/insights";

// Article archetype: Organization (ref) + Person author (audits 10.1–10.3) +
// Article (datePublished/dateModified) + WebPage + BreadcrumbList (audits 3.5,
// 3.6, 3.15, 10.10). One static page per entry in ~/data/insights — add or
// remove articles there and the routes follow automatically.
export function getStaticPaths() {
  return insights.map((insight) => ({
    params: { slug: insight.slug },
    props: { insight },
  }));
}

// getStaticPaths always supplies `insight`; the fallback only keeps this file
// type-safe (and renderable in isolation) if the array is ever emptied.
const insight: Insight = (Astro.props as { insight?: Insight }).insight ?? {
  slug: "$INSIGHT_ONE_SLUG",
  title: "$INSIGHT_ONE_TITLE",
  description: "$INSIGHT_ONE_DESCRIPTION",
  href: "/insights/$INSIGHT_ONE_SLUG/",
  author: {
    slug: "$AUTHOR_ONE_SLUG",
    name: "$AUTHOR_ONE_NAME",
    jobTitle: "$AUTHOR_ONE_JOBTITLE",
    bio: "$AUTHOR_ONE_BIO",
    image: "$AUTHOR_ONE_IMAGE",
    sameAs: ["$AUTHOR_ONE_LINKEDIN"],
    topics: ["$AUTHOR_ONE_TOPIC"],
  },
  publishedAt: "$INSIGHT_ONE_PUBLISHED",
  modifiedAt: "$INSIGHT_ONE_MODIFIED",
  tags: ["$INSIGHT_ONE_TAG"],
  body: "$INSIGHT_ONE_BODY",
  pullquote: "$INSIGHT_ONE_PULLQUOTE",
  citations: [
    { label: "$CITATION_ONE_LABEL", href: "$CITATION_ONE_URL" },
    { label: "$CITATION_TWO_LABEL", href: "$CITATION_TWO_URL" },
  ],
};

const siteUrl = getSiteUrl(Astro.site);
const canonicalHref = new URL(insight.href, siteUrl).toString();
const title = `${insight.title} | ${siteInfo.name}`;

const structuredData = graph(
  organization(siteUrl),
  person(insight.author, siteUrl),
  article({
    siteUrl,
    canonicalHref,
    headline: insight.title,
    description: insight.description,
    datePublished: insight.publishedAt,
    dateModified: insight.modifiedAt,
    author: insight.author,
    about: insight.tags,
    image: insight.heroImage,
  }),
  webPage({
    siteUrl,
    canonicalHref,
    title,
    description: insight.description,
    about: { "@id": `${canonicalHref}#article` },
    speakable: ["h1", ".article-summary"],
  }),
  breadcrumbs([
    { name: siteInfo.name, item: `${siteUrl}/` },
    { name: "Insights", item: `${siteUrl}/insights/` },
    { name: insight.title, item: canonicalHref },
  ]),
);
---

<BaseLayout
  title={title}
  description={insight.description}
  canonicalPath={insight.href}
  type="article"
  author={insight.author.name}
  articlePublishedTime={insight.publishedAt}
  articleModifiedTime={insight.modifiedAt}
  structuredData={structuredData}
>
  <article class="mx-auto max-w-3xl">
    <nav class="text-muted text-sm" aria-label="Breadcrumb">
      <a class="text-ink" href="/insights/">Insights</a> / {insight.title}
    </nav>

    <p class="text-mint mt-6 text-sm font-semibold">Insight</p>
    <h1 class="mt-3 text-4xl leading-tight font-black sm:text-6xl">
      {insight.title}
    </h1>

    {/* Byline: named author (audit 10.1) + visible dates (audits 9.8, 10.9) */}
    <p class="text-muted mt-6">
      By{" "}
      <a class="text-ink font-semibold" href={`/authors/${insight.author.slug}/`}>
        {insight.author.name}
      </a>, {insight.author.jobTitle}
    </p>
    <p class="text-muted mt-1 text-sm">
      Published <time datetime={insight.publishedAt}>{insight.publishedAt}</time>
      · Last updated <time datetime={insight.modifiedAt}>{insight.modifiedAt}</time>
    </p>

    <p class="article-summary mt-8 text-lg leading-8">{insight.description}</p>

    <div class="mt-6 leading-8">
      <p>{insight.body}</p>
    </div>

    {/* audit 10.14 — memorable callout LLMs preferentially cite */}
    <blockquote class="border-lime text-ink my-10 border-l-4 pl-5 text-xl font-semibold italic">
      <p>{insight.pullquote}</p>
    </blockquote>

    {/* audit 6.6 / 10.5 — supplementary sources as an <aside>, ≥2 outbound links */}
    <aside class="border-ink/10 mt-12 border-t pt-6" aria-label="Sources">
      <h2 class="text-sm font-black tracking-wide uppercase">Sources</h2>
      <ul class="mt-3 space-y-2">
        {
          insight.citations.map((c) => (
            <li>
              <a
                class="text-ink font-semibold"
                href={c.href}
                rel="nofollow noopener"
                target="_blank"
              >
                {c.label}
              </a>
            </li>
          ))
        }
      </ul>
    </aside>
  </article>
</BaseLayout>
