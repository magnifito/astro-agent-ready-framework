---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { breadcrumbs, collectionPage, graph } from "~/lib/schema";
import { insights } from "~/data/insights";
import { getSiteUrl, siteInfo } from "~/data/site";

// Article index archetype: CollectionPage (mainEntity ItemList) +
// BreadcrumbList (audit 3.5). Driven by ~/data/insights.
const siteUrl = getSiteUrl(Astro.site);
const canonicalHref = new URL("/insights/", siteUrl).toString();
const title = `Insights | ${siteInfo.name}`;
const description = `Articles and analysis from the ${siteInfo.name} team.`;

const structuredData = graph(
  collectionPage({
    siteUrl,
    canonicalHref,
    title,
    description,
    items: insights.map((i) => ({
      name: i.title,
      description: i.description,
      url: new URL(i.href, siteUrl).toString(),
    })),
  }),
  breadcrumbs([
    { name: siteInfo.name, item: `${siteUrl}/` },
    { name: "Insights", item: canonicalHref },
  ]),
);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/insights/"
  structuredData={structuredData}
>
  <div class="mx-auto max-w-4xl">
    <h1 class="text-4xl leading-tight font-black sm:text-6xl">Insights</h1>
    <p class="text-muted mt-6 max-w-2xl text-lg leading-8">{description}</p>

    <ul class="mt-12 divide-y">
      {
        insights.map((post) => (
          <li class="py-6">
            {/* audit 6.4 — each post preview is an <article> */}
            <article>
              <h2 class="text-2xl font-black">
                <a class="text-ink" href={post.href}>
                  {post.title}
                </a>
              </h2>
              <p class="text-muted mt-2 text-sm">
                {post.author.name} —{" "}
                <time datetime={post.publishedAt}>{post.publishedAt}</time>
              </p>
              <p class="mt-3 leading-7">{post.description}</p>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
