---
import "@fontsource-variable/inter";
import SeoHead from "~/components/SeoHead.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import SiteHeader from "~/components/SiteHeader.astro";
import { authors } from "~/data/authors";
import { getSiteUrl, siteInfo } from "~/data/site";
import "~/styles/index.css";

const title = `Authors | ${siteInfo.name}`;
const description = `Named authors contributing to ${siteInfo.name}.`;
const siteUrl = getSiteUrl(Astro.site);
const canonicalHref = new URL("/authors/", siteUrl).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${canonicalHref}#webpage`,
      url: canonicalHref,
      name: title,
      description,
      isPartOf: { "@type": "WebSite", "@id": `${siteUrl}/#website`, name: siteInfo.name, url: siteUrl },
      mainEntity: {
        "@type": "ItemList",
        itemListElement: authors.map((author, i) => ({
          "@type": "ListItem",
          position: i + 1,
          url: new URL(`/authors/${author.slug}/`, siteUrl).toString(),
          name: author.name,
          description: author.jobTitle,
        })),
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead title={title} description={description} canonicalPath="/authors/" structuredData={structuredData} />
  </head>
  <body class="bg-paper text-ink min-h-screen antialiased">
    <SiteHeader />
    <main id="main" class="px-5 py-16 sm:px-8 lg:px-10">
      <div class="mx-auto max-w-4xl">
        <h1 class="text-4xl font-black sm:text-6xl">Authors</h1>
        <ul class="mt-12 divide-y">
          {authors.map((author) => (
            <li class="py-6">
              <a class="text-ink text-2xl font-black" href={`/authors/${author.slug}/`}>{author.name}</a>
              <p class="text-muted mt-1">{author.jobTitle}</p>
              <p class="mt-3 leading-7">{author.bio}</p>
            </li>
          ))}
        </ul>
      </div>
    </main>
    <SiteFooter />
  </body>
</html>
