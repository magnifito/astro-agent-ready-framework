---
// Static search powered by astro-pagefind. After build, pagefind indexes
// dist/ and emits /pagefind/ assets served at /pagefind/pagefind.js.
//
// Makes WebSite.SearchAction real (audit 3.4). Also satisfies audit 5.16
// (search endpoint functional) and part of category 12 (voice search).
//
// The WebSite.SearchAction URL template in structured-data-patterns.md
// is `${siteUrl}/search/?q={search_term_string}`. This page reads `q` from
// the URL on mount and kicks off a search.
import "@fontsource-variable/inter";
import SeoHead from "~/components/SeoHead.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import SiteHeader from "~/components/SiteHeader.astro";
import { getSiteUrl, siteInfo } from "~/data/site";
import "~/styles/index.css";

const title = `Search | ${siteInfo.name}`;
const description = `Search ${siteInfo.name} content. Powered by a pre-built static index.`;
const siteUrl = getSiteUrl(Astro.site);
const canonicalHref = new URL("/search/", siteUrl).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SearchResultsPage",
  "@id": `${canonicalHref}#webpage`,
  url: canonicalHref,
  name: title,
  isPartOf: { "@type": "WebSite", "@id": `${siteUrl}/#website`, name: siteInfo.name, url: siteUrl },
};
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonicalPath="/search/"
      structuredData={structuredData}
      robots="noindex, follow"
    />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </head>
  <body class="bg-paper text-ink min-h-screen antialiased">
    <SiteHeader />
    <main id="main" class="px-5 py-16 sm:px-8 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-black sm:text-6xl">Search</h1>
        <div id="search" class="mt-10"></div>
      </div>
    </main>
    <SiteFooter />
    <script>
      // @ts-nocheck
      import { PagefindUI } from "/pagefind/pagefind-ui.js";
      const ui = new PagefindUI({ element: "#search", showImages: false });
      const q = new URLSearchParams(location.search).get("q");
      if (q) {
        const input = document.querySelector("#search .pagefind-ui__search-input");
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event("input", { bubbles: true }));
        }
      }
    </script>
  </body>
</html>
