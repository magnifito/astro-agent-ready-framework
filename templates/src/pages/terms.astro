---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { breadcrumbs, graph, webPage } from "~/lib/schema";
import { getSiteUrl, siteInfo } from "~/data/site";

// Honest stub — replace $TOKEN copy with real terms before launch.
// WebPage + BreadcrumbList JSON-LD; visible "Last updated" <time> (audits 6.11,
// 9.10). Category 8 requires /privacy/ + /terms/ to exist, even as stubs.
const siteUrl = getSiteUrl(Astro.site);
const canonicalHref = new URL("/terms/", siteUrl).toString();
const title = `Terms of Service | ${siteInfo.name}`;
const description = `The terms that govern use of the ${siteInfo.name} website and services.`;
const lastUpdated = "$LEGAL_LAST_UPDATED"; // ISO date, e.g. 2026-01-01

const structuredData = graph(
  webPage({ siteUrl, canonicalHref, title, description }),
  breadcrumbs([
    { name: siteInfo.name, item: `${siteUrl}/` },
    { name: "Terms", item: canonicalHref },
  ]),
);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/terms/"
  structuredData={structuredData}
>
  <article class="mx-auto max-w-3xl">
    <h1 class="text-4xl leading-tight font-black sm:text-6xl">
      Terms of Service
    </h1>
    <p class="text-muted mt-4">
      Last updated <time datetime={lastUpdated}>{lastUpdated}</time>
    </p>

    <p class="mt-8 leading-8">
      These terms govern your use of the {siteInfo.name} website and services.
      They are a starting template — replace the sections below with terms
      reviewed by your own counsel.
    </p>

    <h2 class="mt-12 text-2xl font-black">Use of the site</h2>
    <p class="mt-3 leading-8">$TERMS_USE_OF_SITE</p>

    <h2 class="mt-10 text-2xl font-black">Intellectual property</h2>
    <p class="mt-3 leading-8">$TERMS_INTELLECTUAL_PROPERTY</p>

    <h2 class="mt-10 text-2xl font-black">Disclaimers and liability</h2>
    <p class="mt-3 leading-8">$TERMS_LIABILITY</p>

    <h2 class="mt-10 text-2xl font-black">Changes to these terms</h2>
    <p class="mt-3 leading-8">$TERMS_CHANGES</p>

    <h2 class="mt-10 text-2xl font-black">Contact</h2>
    <p class="mt-3 leading-8">Questions about these terms? Reach us at:</p>
    <address class="mt-3 not-italic">
      <a class="text-ink font-semibold" href={`mailto:${siteInfo.email}`}>
        {siteInfo.email}
      </a>
    </address>
  </article>
</BaseLayout>
