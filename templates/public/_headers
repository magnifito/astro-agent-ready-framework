# Netlify / Cloudflare Pages header file.
# Use instead of public/.htaccess when deploying to these platforms.
# Syntax: path block, then indented `Header-Name: value` lines.

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # Cross-Origin isolation. DISABLED by default: require-corp blocks any
  # cross-origin image/font/script lacking CORP/CORS headers (this template
  # preconnects to images.unsplash.com, so a CDN hero would break). Enable ONLY
  # if the site needs cross-origin isolation AND every embedded cross-origin
  # resource sends CORP or CORS headers.
  # Cross-Origin-Opener-Policy: same-origin
  # Cross-Origin-Embedder-Policy: require-corp
  # Cross-Origin-Resource-Policy: same-site
  # Enable HSTS only once HTTPS-only:
  # Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # Tune CSP per site:
  # Content-Security-Policy: default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; form-action 'self' https://api.web3forms.com; frame-ancestors 'self'

