---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { breadcrumbs, graph, webPage } from "~/lib/schema";
import { getSiteUrl, siteInfo } from "~/data/site";

// Honest stub — replace $TOKEN copy with a real policy before launch.
// WebPage + BreadcrumbList JSON-LD; visible "Last updated" <time> (audits 6.11,
// 9.10). Category 8 requires /privacy/ + /terms/ to exist, even as stubs.
const siteUrl = getSiteUrl(Astro.site);
const canonicalHref = new URL("/privacy/", siteUrl).toString();
const title = `Privacy Policy | ${siteInfo.name}`;
const description = `How ${siteInfo.name} collects, uses, and protects personal information.`;
const lastUpdated = "$LEGAL_LAST_UPDATED"; // ISO date, e.g. 2026-01-01

const structuredData = graph(
  webPage({ siteUrl, canonicalHref, title, description }),
  breadcrumbs([
    { name: siteInfo.name, item: `${siteUrl}/` },
    { name: "Privacy", item: canonicalHref },
  ]),
);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/privacy/"
  structuredData={structuredData}
>
  <article class="mx-auto max-w-3xl">
    <h1 class="text-4xl leading-tight font-black sm:text-6xl">Privacy Policy</h1>
    <p class="text-muted mt-4">
      Last updated <time datetime={lastUpdated}>{lastUpdated}</time>
    </p>

    <p class="mt-8 leading-8">
      This policy explains what personal information {siteInfo.name} collects,
      why we collect it, and the choices you have. It is a starting template —
      replace the sections below with your organisation's real practices.
    </p>

    <h2 class="mt-12 text-2xl font-black">Information we collect</h2>
    <p class="mt-3 leading-8">$PRIVACY_INFORMATION_COLLECTED</p>

    <h2 class="mt-10 text-2xl font-black">How we use information</h2>
    <p class="mt-3 leading-8">$PRIVACY_INFORMATION_USE</p>

    <h2 class="mt-10 text-2xl font-black">Sharing and third parties</h2>
    <p class="mt-3 leading-8">$PRIVACY_THIRD_PARTIES</p>

    <h2 class="mt-10 text-2xl font-black">Your rights</h2>
    <p class="mt-3 leading-8">$PRIVACY_YOUR_RIGHTS</p>

    <h2 class="mt-10 text-2xl font-black">Contact</h2>
    <p class="mt-3 leading-8">
      Questions about this policy? Reach us at:
    </p>
    <address class="mt-3 not-italic">
      <a class="text-ink font-semibold" href={`mailto:${siteInfo.email}`}>
        {siteInfo.email}
      </a>
    </address>
  </article>
</BaseLayout>
